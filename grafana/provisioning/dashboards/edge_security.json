{
  "title": "Edge Security Monitor",
  "uid": "edge-security",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Telemetry Message Rate (msg/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(mqtt_messages_total[1m]) * 60",
          "legendFormat": "msg/min"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Security Alerts",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "mqtt_alerts_total",
          "legendFormat": "alerts"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Blocked Messages",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "mqtt_blocked_total",
          "legendFormat": "blocked"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red",    "value": 20 }
            ]
          }
        }
      }
    }
  ]
}
