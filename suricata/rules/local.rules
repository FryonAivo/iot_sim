# ─── MQTT Flood Detection ─────────────────────────────────────────────────────
# Alert when a single source sends 100+ TCP segments to the MQTT port in 10 s
alert tcp any any -> any 1883 (msg:"MQTT Flood Detected"; threshold: type threshold, track by_src, count 100, seconds 10; sid:1000001; rev:1;)

# ─── MQTT Brute Force Auth Detection ──────────────────────────────────────────
# MQTT CONNECT packet starts with 0x10; 5+ attempts from same IP in 30 s = brute force
alert tcp any any -> any 1883 (msg:"MQTT Brute Force Auth"; content:"|10|"; offset:0; depth:1; threshold: type threshold, track by_src, count 5, seconds 30; sid:1000002; rev:1;)
